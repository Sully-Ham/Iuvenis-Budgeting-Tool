# Copy this file to ".env" in the same folder and fill in real values.
# ".env" itself is gitignored, so your secrets never get committed.

# Get this from your Supabase project: Project Settings -> Database -> Connection string
# (use the "URI" format, and make sure to swap in your actual database password)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_PROJECT_REF.supabase.co:5432/postgres

# Any long random string — this signs login sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string
